        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Helvetica Neue', Arial, sans-serif; }
        body { background-color: #0B132B; color: #FFFFFF; line-height: 1.6; overflow-x: hidden; }
        
        /* Navigation Hub */
        nav { display: flex; justify-content: space-between; align-items: center; padding: 25px 10%; background: rgba(11, 19, 43, 0.95); position: fixed; width: 100%; top: 0; z-index: 1000; border-bottom: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(10px); }

        .logo span { color: #FFB703; }
        .nav-links { display: flex; list-style: none; }
        .nav-links li { margin-left: 35px; }
        .nav-links a { text-decoration: none; color: #BDC3C7; font-size: 14px; font-weight: 500; letter-spacing: 1px; transition: color 0.3s; }
        .nav-links a:hover { color: #FFB703; }
        
        /* Premium Hero Banner Section */
        .hero { min-height: 100vh; display: flex; align-items: center; padding: 0 10%; background: radial-gradient(circle at top right, rgba(29, 38, 113, 0.4), #0B132B); pt: 80px; }
        .hero-content { max-width: 800px; }
        .tagline { color: #FFB703; font-size: 13px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 20px; }
        h1 { font-size: 52px; font-weight: 800; line-height: 1.15; letter-spacing: -1px; margin-bottom: 25px; color: #FFFFFF; }
        h1 span { display: block; color: rgba(255,255,255,0.7); font-size: 40px; font-weight: 300; margin-top: 5px; }
        p { font-size: 18px; color: #AFB6C5; margin-bottom: 40px; max-width: 650px; }
        
        /* Action Call Buttons */
        .btn-group { display: flex; gap: 20px; }
        .btn { display: inline-block; padding: 16px 35px; border-radius: 4px; font-size: 14px; font-weight: 600; letter-spacing: 1px; text-decoration: none; transition: all 0.3s ease; }
        .btn-primary { background-color: #FFB703; color: #0B132B; }
        .btn-primary:hover { background-color: #E09F00; transform: translateY(-2px); }
        .btn-secondary { border: 1px solid rgba(255,255,255,0.2); color: #FFFFFF; }
        .btn-secondary:hover { background: rgba(255,255,255,0.05); transform: translateY(-2px); }
    </style>
